    {
      "parameters": {
        "jsCode": "const lead = $json;\n\nconst status = lead.statusCode ?? 0;\n\nconst reachable = status >= 200 && status < 400;\n\nconst httpsEnabled = lead.audit_url\n  ? lead.audit_url.startsWith(\"https://\")\n  : false;\n\nlet score = 0;\n\nif (reachable) score += 40;\nif (httpsEnabled) score += 20;\nif (status === 200) score += 40;\n\nlet priority = \"High\";\n\nif (score >= 80) {\n  priority = \"Low\";\n} else if (score >= 60) {\n  priority = \"Medium\";\n}\n\nconst issues = {\n  seo: [],\n  performance: [],\n  security: [],\n  accessibility: []\n};\n\nif (!httpsEnabled) {\n  issues.security.push(\"Website does not use HTTPS\");\n}\n\nif (!reachable) {\n  issues.performance.push(\"Website is unreachable\");\n}\n\nif (status !== 200) {\n  issues.performance.push(`HTTP status ${status}`);\n}\n\nconst recommendations = {\n  immediate: [],\n  future: []\n};\n\nif (!httpsEnabled) {\n  recommendations.immediate.push(\"Enable HTTPS with a valid SSL certificate.\");\n}\n\nif (!reachable) {\n  recommendations.immediate.push(\"Restore website availability.\");\n}\n\nif (status !== 200 && reachable) {\n  recommendations.future.push(\"Investigate non-200 HTTP responses.\");\n}\n\nreturn {\n  json: {\n    ...lead,\n\n    reachable,\n    status_code: status,\n    https_enabled: httpsEnabled,\n    redirect_url: null,\n    response_time_ms: null,\n    checked_at: new Date().toISOString(),\n\n    audit_score: score,\n    priority,\n\n    issues,\n    recommendations\n  }\n};"
      },
