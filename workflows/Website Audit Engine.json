    {
      "parameters": {
        "jsCode": "return items.map(item => {\n\n  const a = item.json.audit;\n\n  let score = 100;\n  const issues = [];\n\n  if (!a.hasTitle) {\n    score -= 15;\n    issues.push(\"Missing title tag\");\n  }\n\n  if (!a.hasMetaDescription) {\n    score -= 20;\n    issues.push(\"Missing meta description\");\n  }\n\n  if (!a.hasH1) {\n    score -= 10;\n    issues.push(\"Missing H1\");\n  }\n\n  if (!a.hasContactPage) {\n    score -= 15;\n    issues.push(\"No contact page\");\n  }\n\n  if (!a.hasAboutPage) {\n    score -= 10;\n    issues.push(\"No about page\");\n  }\n\n  if (!a.hasPrivacyPolicy) {\n    score -= 10;\n    issues.push(\"No privacy policy\");\n  }\n\n  if (!a.hasSSL) {\n    score -= 20;\n    issues.push(\"Website not using HTTPS\");\n  }\n\n  let priority = \"Low\";\n\n  if (score < 50) {\n    priority = \"High\";\n  } else if (score < 75) {\n    priority = \"Medium\";\n  }\n\n  return {\n    json: {\n      ...item.json,\n\n      opportunity_score: score,\n\n      priority,\n\n      issues\n    }\n  };\n\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1072,
        -192
      ],
      "id": "ec28d4a7-0416-46fd-bd15-769470ea2c42",
      "name": "Opportunity Score",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n\n  const html = item.json.data || \"\";\n\n  const audit = {\n    title: null,\n    hasTitle: false,\n\n    hasMetaDescription: false,\n\n    hasH1: false,\n\n    hasContactPage: false,\n\n    hasAboutPage: false,\n\n    hasPrivacyPolicy: false,\n\n    hasSSL: item.json.audit_url.startsWith(\"https\"),\n\n    htmlLength: html.length\n  };\n\n  // Title\n  const title = html.match(/<title>(.*?)<\\/title>/i);\n\n  if (title) {\n    audit.title = title[1];\n    audit.hasTitle = true;\n  }\n\n  // Meta Description\n  audit.hasMetaDescription =\n    /meta\\s+name=[\"']description[\"']/i.test(html);\n\n  // H1\n  audit.hasH1 =\n    /<h1/i.test(html);\n\n  // Contact\n  audit.hasContactPage =\n    /contact/i.test(html);\n\n  // About\n  audit.hasAboutPage =\n    /about/i.test(html);\n\n  // Privacy\n  audit.hasPrivacyPolicy =\n    /privacy/i.test(html);\n\n  return {\n    json: {\n      ...item.json,\n      audit\n    }\n  };\n\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        848,
        -192
      ],
      "id": "90d0342b-0296-41a9-8501-6918f24a906b",
      "name": "Website Audit"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  let url = (item.json.website || \"\").trim();\n\n  // Ignore emails\n  if (url.includes(\"@\")) {\n    return {\n      json: {\n        ...item.json,\n        audit_url: null\n      }\n    };\n  }\n\n  // Remove Markdown links\n  const md = url.match(/^\\[([^\\]]+)\\]\\([^)]+\\)$/);\n  if (md) {\n    url = md[1];\n  }\n\n  // Add protocol if missing\n  if (!/^https?:\\/\\//i.test(url)) {\n    url = \"https://\" + url;\n  }\n\n  return {\n    json: {\n      ...item.json,\n      audit_url: url\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        176,
        -192
      ],
      "id": "de90649d-6107-4e58-a17d-d371c3933629",
